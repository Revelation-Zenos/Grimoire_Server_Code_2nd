[Unit]
Description=HS iptables RCON policy (ensure RCON on server IP is blocked)
After=network.target

[Service]
Type=oneshot
RemainAfterExit=yes
WorkingDirectory=/home/ezel/Game Server/HS_TestServer
ExecStart=/bin/bash -lc "cd '/home/ezel/Game Server/HS_TestServer' && /bin/bash scripts/hs-iptables.sh"
ExecReload=/bin/bash -lc "cd '/home/ezel/Game Server/HS_TestServer' && /bin/bash scripts/hs-iptables.sh"

[Install]
WantedBy=multi-user.target
